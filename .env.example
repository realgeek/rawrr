# Rawrr Configuration Example (.env file)

# Core timing settings
RAWRR_STARTUP_DELAY_SECS=30
RAWRR_POLL_INTERVAL_SECS=3600
RAWRR_RELEASE_DELAY_HOURS=6

# State persistence
RAWRR_STATE_FILE=/var/lib/rawrr/state.json

# Docker daemon connection
DOCKER_HOST=unix:///var/run/docker.sock

# Label name for container monitoring policy (optional - this is the default)
# Values: ignore/false/off, notify, update
RAWRR_LABEL_POLICY=rawrr.policy

# Rate limiting
RAWRR_RATE_LIMIT_MAX_POLLS=100
RAWRR_RATE_LIMIT_WINDOW_SECS=3600

# Registry credentials (optional, but recommended for Docker Hub when monitoring many images)
# Format: comma-separated registry=username:token pairs
# docker.io credentials also cover images with no explicit registry prefix
# ghcr.io credentials also cover lscr.io images (same auth backend)
# RAWRR_REGISTRY_CREDENTIALS=docker.io=myuser:dckr_pat_xxxx,ghcr.io=myuser:ghp_xxxx

# Notifier selection: "gotify", "ntfy", or empty to disable
RAWRR_NOTIFIER=gotify

# Gotify settings (required if RAWRR_NOTIFIER=gotify)
RAWRR_GOTIFY_URL=http://gotify:80
RAWRR_GOTIFY_TOKEN=your-token-here

# ntfy settings (required if RAWRR_NOTIFIER=ntfy)
# RAWRR_NOTIFIER=ntfy
# RAWRR_NTFY_URL=https://ntfy.sh
# RAWRR_NTFY_TOPIC=my-docker-updates

# Logging
RUST_LOG=rawrr=debug,info
